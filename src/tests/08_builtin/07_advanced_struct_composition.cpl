//OUT=10

struct Vec
    size
    vec

    fn index i
        ret &_builtin_index(self.vec i)

fn new_vec size
    ret Vec size size vec _builtin_alloc(size)

fn new_vec
    ret new_vec(0)

struct Box[T]
    x: T

    fn to_vec
        vec = new_vec(1)
        |vec.index(0) = self.x
        ret vec

fn main
    box = Box x 10
    vec = box.to_vec()
    out "{|vec.index(0)}"